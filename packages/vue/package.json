{
  "name": "@anchor-sdk/vue",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/anchor-vue.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/anchor-vue.js"
    }
  },
  "files": [
    "dist"
