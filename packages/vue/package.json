  },
  "dependencies": {
    "@anchor-sdk/core": "workspace:*"
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "typescript": "^5.4.0",
    "vite": "^6.0.0",
    "vue": "^3.4.0",
    "vue-tsc": "^2.0.0"
  }
}
