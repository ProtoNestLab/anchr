{
  "name": "@anchor-sdk/ui",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/anchor-ui.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/anchor-ui.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && vue-tsc --declaration --emitDeclarationOnly --outDir dist",
